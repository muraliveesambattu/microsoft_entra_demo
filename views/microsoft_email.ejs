<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Microsoft SSO — Enter Email</title>
  <style>
    body { font-family: 'Segoe UI', system-ui, sans-serif; background: #0f172a; color: #e2e8f0; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .card { background: #1e293b; border: 1px solid #334155; border-radius: 16px; padding: 40px 36px; width: 100%; max-width: 420px; box-shadow: 0 25px 60px rgba(0,0,0,.4); }
    h1 { text-align: center; font-size: 1.5rem; color: #f8fafc; margin-bottom: 18px; }
    .error { background: #450a0a; border: 1px solid #7f1d1d; color: #fca5a5; padding: 10px 14px; border-radius: 8px; font-size: .95rem; margin-bottom: 18px; }
    label { display: block; font-size: .95rem; color: #94a3b8; margin-bottom: 4px; }
    input[type="email"] { width: 100%; padding: 10px 14px; border: 1px solid #334155; border-radius: 8px; background: #0f172a; color: #f8fafc; font-size: 1rem; margin-bottom: 14px; }
    input:focus { outline: none; border-color: #3b82f6; }
    .btn { width: 100%; padding: 12px; border: none; border-radius: 8px; font-size: 1rem; font-weight: 600; background: #3b82f6; color: #fff; cursor: pointer; transition: background .2s; }
    .btn:hover { background: #2563eb; }
  </style>
</head>
<body>
  <div class="card">
    <h1>Sign in with Microsoft</h1>
    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>
    <form method="POST" action="/auth/microsoft/email" style="display: flex; flex-direction: column; gap: 18px; width: 100%;">
      <label for="email" style="text-align:left;">Enter your work or school email</label>
      <input type="email" id="email" name="email" placeholder="you@company.com" required style="width: 100%; box-sizing: border-box; margin-bottom: 0; min-height: 44px; font-size: 1rem;" value="<%= email %>" />
      <button type="submit" class="btn" style="width: 100%; min-height: 44px; font-size: 1rem;">Check SSO Configuration</button>
    </form>

    <% if (showMicrosoftButton) { %>
      <form method="POST" action="/auth/microsoft/start" style="margin-top: 18px;">
        <input type="hidden" name="email" value="<%= email %>" />
        <button type="submit" class="btn" style="display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; min-height: 44px; font-size: 1rem; background: #3b82f6; color: #fff;">
          <svg viewBox="0 0 21 21" xmlns="http://www.w3.org/2000/svg" style="vertical-align:middle;width:20px;height:20px;"><rect x="1"  y="1"  width="9" height="9" fill="#f25022"/><rect x="11" y="1"  width="9" height="9" fill="#7fba00"/><rect x="1"  y="11" width="9" height="9" fill="#00a4ef"/><rect x="11" y="11" width="9" height="9" fill="#ffb900"/></svg>
          Login With Microsoft
        </button>
      </form>
    <% } %>
  </div>
</body>
</html>
